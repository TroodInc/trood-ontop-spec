{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "nodeKinds", "edgeKinds", "ruleKinds"],
  "properties": {
    "version": { "const": "0.1" },
    "nodeKinds": {
      "type": "array",
      "minItems": 1,
      "items": { "const": "service" }
    },
    "edgeKinds": {
      "type": "array",
      "minItems": 1,
      "items": { "const": "depends_on" }
    },
    "ruleKinds": {
      "type": "array",
      "minItems": 1,
      "items": { "const": "forbid_dependency" }
    }
  }
}
