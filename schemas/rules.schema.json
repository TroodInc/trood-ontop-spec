{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "const": "0.1" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "from", "to"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "const": "forbid_dependency" },
          "from": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node"],
            "properties": {
              "node": { "type": "string" }
            }
          },
          "to": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node"],
            "properties": {
              "node": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
